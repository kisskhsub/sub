2203
01:27:17,191 --> 01:27:18,567
[roars]

2204
01:27:18,651 --> 01:27:19,944
[both growling]

2205
01:27:25,074 --> 01:27:26,367
[growls]

2206
01:27:26,450 --> 01:27:27,493
[growls]

2207
